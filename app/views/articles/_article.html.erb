<div id="<%= dom_id article %>" class="article">
  <div class="article__header">
    <h2 class="article__title"><%= article.title %></h2>
    <div class="article__excerpt">
      <%= sanitize article.excerpt %>
    </div>
  </div>

  <dl class="article__meta">
    <% if article.published_at.present? %>
    <div class="article__meta-item">
        <dt class="article__meta-label">Published at</dt>
        <dd class="article__meta-value"><%= article.published_at.strftime("%B %d, %Y") %></dd>
      </div>
    <% end %>

    <div class="article__meta-item">
      <dt class="article__meta-label">Categories</dt>
      <dd class="article__meta-value">
        <div class="article__categories">
          <% article.categories.each do |category| %>
            <span class="article__category-badge"><%= category.name %></span>
          <% end %>
        </div>
      </dd>
    </div>
  </dl>

  <div class="article__actions">
    <% if (blog_url = UriSanitizerHelper.safe_external_url(article.wordpress_url)) %>
      <%= link_to "View the blog post", blog_url, target: "_blank", rel: "noopener", class: "article__link" %>
    <% end %>
  </div>
</div>
