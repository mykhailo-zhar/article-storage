<p style="color: green"><%= notice %></p>
<% if flash[:alert].present? %>
  <p style="color: red"><%= flash[:alert] %></p>
<% end %>

<% content_for :title, "Articles" %>

<h1>Articles</h1>

<%= form_with url: articles_path, method: :get, local: true do |form| %>
  <div>
    <%= label_tag :search, "What are you looking for?" %>
    <%= text_field_tag :search, @search_query %>
  </div>

  <fieldset>
    <legend>Search type</legend>
    <% Articles::SearchFactory::TYPES.each do |key, label| %>
      <div>
        <%= radio_button_tag :type, key, @type == key, id: "type_#{key}" %>
        <%= label_tag "type_#{key}", label %>
      </div>
    <% end %>
  </fieldset>

  <fieldset>
    <legend>Categories</legend>
    <% Articles::SearchKeywords::CATEGORIES_NAMES.each do |key, label| %>
      <div>
        <%= radio_button_tag "categories[]", key, @selected_categories.include?(key), id: "categories_#{key}" %>
        <%= label_tag "categories_#{key}", label %>
      </div>
    <% end %>
  </fieldset>

  <%= form.submit "Search" %>
<% end %>

<% if @articles.empty? && flash[:alert].blank? %>
  <p>No articles found.</p>
<% end %>

<div id="articles">
  <% @articles.each do |article| %>
    <%= render article %>
  <% end %>
</div>

<% if @page > 1 || @total_pages.present? && @total_pages > @page %>
  <nav class="pagination" aria-label="Articles pagination">
    <div class="pagination__controls">
      <% if @page > 1 %>
        <%= link_to "Previous",
              articles_path(search: @search_query, categories: @selected_categories, page: @page - 1, type: @type),
              class: "pagination__button" %>
      <% end %>

      <%= form_with url: articles_path, method: :get, local: true, class: "pagination__page-form" do %>
        <%= hidden_field_tag :search, @search_query %>
        <% @selected_categories.each do |category| %>
          <%= hidden_field_tag "categories[]", category %>
        <% end %>
        <%= hidden_field_tag :type, @type %>

        <span class="pagination__current">
          <label for="page">Page</label>
          <%= number_field_tag :page,
                @page,
                min: 1,
                max: @total_pages,
                id: "page",
                class: "pagination__page-input",
                "aria-label": "Page number" %>
          <span>of <%= @total_pages %></span>
        </span>

        <%= submit_tag "Go", class: "pagination__button" %>
      <% end %>

      <% if @total_pages.present? && @total_pages > @page %>
        <%= link_to "Next",
              articles_path(search: @search_query, categories: @selected_categories, page: @page + 1, type: @type),
              class: "pagination__button" %>
      <% end %>
    </div>
  </nav>
<% end %>
