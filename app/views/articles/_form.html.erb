<%= form_with(model: article) do |form| %>
  <% if article.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>

      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :excerpt, style: "display: block" %>
    <%= form.textarea :excerpt %>
  </div>

  <div>
    <%= form.label :wordpress_url, style: "display: block" %>
    <%= form.text_field :wordpress_url %>
  </div>

  <div>
    <%= form.label :wordpress_id, style: "display: block" %>
    <%= form.number_field :wordpress_id %>
  </div>

  <div>
    <%= form.label :published_at, style: "display: block" %>
    <%= form.datetime_field :published_at %>
  </div>

  <div>
    <%= form.label :category_ids, "Categories", style: "display: block" %>
    <%= form.collection_check_boxes :category_ids, Category.order(:name), :id, :name %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
